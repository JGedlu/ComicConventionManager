@model List<ComicConventionManager.Models.Panel>

<div class="dashboard-layout">
    <aside class="sidebar">
        <a asp-controller="Notice" asp-action="Index">Notices</a>
        <a href="#">Guests</a>
        <a href="#">Location</a>

        @if (User.IsInRole("Admin"))
        {
            <a asp-controller="Panel" asp-action="Manage" style="color:red;">Manage Panels</a>
            <a asp-controller="Notice" asp-action="Manage" style="color:red;">Manage Notices</a>
        }
    </aside>

    <main class="panel-area">
        <div class="page-header">
            <h1>My Schedule</h1>
        </div>

        @if (Model.Count == 0)
        {
            <div class="empty-schedule">
                <p>You haven't added any panels yet.</p>

                <a asp-controller="Home"
                   asp-action="Index"
                   class="browse-panels">
                    Browse Panels
                </a>
            </div>
        }

        @foreach (var panel in Model)
        {
            <div class="panel-card">
                <div class="panel-header">
                    <h3>@panel.Title</h3>
                    <a asp-controller="Schedule"
                       asp-action="Remove"
                       asp-route-id="@panel.PanelId"
                       asp-route-returnUrl="@Context.Request.Path"
                       class="schedule-btn remove">
                        −
                    </a>
                </div>

                <p>@panel.Description</p>
                <div class="panel-meta">

                    @{
                        string formattedDate;
                        if (panel.EndDate != null)
                        {
                            formattedDate =
                            $"{panel.StartDate:MMMM d} – {panel.EndDate:MMMM d, yyyy}";
                        }
                        else if (panel.StartTime != null)
                        {
                            formattedDate =
                            $"{panel.StartDate:MMMM d, yyyy} · {DateTime.Today.Add(panel.StartTime.Value):h:mm tt}";
                        }
                        else
                        {
                            formattedDate =
                            $"{panel.StartDate:MMMM d, yyyy}";
                        }
                    }

                    @formattedDate
                    · @panel.LocationName

                    @if (!string.IsNullOrEmpty(panel.GoogleMapsLink))
                    {
                        <a href="@panel.GoogleMapsLink"
                           target="_blank"
                           class="map-link">
                            View Map
                        </a>
                    }
                </div>
            </div>
        }
    </main>
</div>